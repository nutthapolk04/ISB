{
  "name": "@isb/backend-bun",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "watch": "nodemon",
    "build": "bun build ./src/server.ts --outdir ./dist --target bun --minify --sourcemap=linked && mkdir -p dist/fixtures && cp src/services/fixtures/*.json dist/fixtures/",
    "staging:start": "bun run build && pm2 start ./staging.config.cjs",
    "staging:stop": "pm2 stop ./staging.config.cjs",
    "staging:restart": "pm2 stop ./staging.config.cjs && bun run build && pm2 start ./staging.config.cjs",
    "staging:logs": "pm2 logs ./staging.config.cjs",
    "staging:flush": "pm2 flush ./staging.config.cjs",
    "prod:start": "bun run build && pm2 start ./production.config.cjs",
    "prod:stop": "pm2 stop ./production.config.cjs",
    "prod:restart": "pm2 stop ./production.config.cjs && bun run build && pm2 start ./production.config.cjs",
    "prod:logs": "pm2 logs ./production.config.cjs",
    "prod:flush": "pm2 flush ./production.config.cjs",
    "pm2:ps": "pm2 ps",
    "pm2:setup": "pm2 install pm2-logrotate && pm2 set pm2-logrotate:max_size 30M && pm2 set pm2-logrotate:rotateInterval '0 0 * * *' && pm2 set pm2-logrotate:retain 14 && pm2 set pm2-logrotate:compress true",
    "start": "bun src/index.ts",
    "test": "bun test",
    "db:introspect": "drizzle-kit introspect",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed-kiosk": "bun scripts/seed-kiosk-user.ts",
    "db:seed-demo": "bun scripts/seed-demo-users.ts",
    "loadtest": "bun scripts/loadtest.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.0",
    "@elysiajs/jwt": "1.4.1",
    "@elysiajs/swagger": "^1.3.0",
    "@isb/shared": "workspace:*",
    "drizzle-orm": "^0.44.6",
    "elysia": "1.4.22",
    "elysia-ip": "^1.1.1",
    "nodemailer": "^9.0.0",
    "postgres": "^3.4.7",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/nodemailer": "^8.0.1",
    "autocannon": "^8.0.0",
    "bun-types": "^1.3.14",
    "drizzle-kit": "^0.31.5",
    "typescript": "^5.9.0"
  }
}
