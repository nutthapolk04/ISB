# Copy to .env and fill in values

# Postgres connection (use Railway DATABASE_PUBLIC_URL for dev against prod)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# JWT — MUST match FastAPI's SECRET_KEY so tokens issued by either backend interop
JWT_SECRET=change_me

# Server port
PORT=3001

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,https://isb-beta.vercel.app

# Frontend base URL (used for PYMT EASYPay browser redirect after payment)
FRONTEND_BASE_URL=https://isb-beta.vercel.app

# Backend public URL — used to build BAY EASYPay return URLs so BAY POST-redirects
# hit the backend (which 302 GET-redirects to the frontend) instead of Vercel static hosting.
BACKEND_BASE_URL=https://your-service.railway.app

# PYMT gateway (BAY QR PromptPay + EASYPay). Leave blank to disable —
# bay_qr / bay_easypay payment methods will return 503 in that case while
# qr_promptpay (mock) + cash continue to work.
PYMT_BASE_URL=elele
PYMT_MERCHANT_TOKEN=

# Optional — "prod" or "uat". Sets subMerchantCode on outgoing BAY QR
# requests (PROD / UAT respectively); leave unset locally to omit the field
# entirely. Not NODE_ENV — staging and production both run with
# NODE_ENV=production by design, so this is a separate flag (see
# staging.config.cjs / production.config.cjs).
APP_ENV=

# ISB vendor sync (POST /api/v1/sync/*) — x-api-key header
ISB_SYNC_API_KEY=

# ISB profile photos (local SFTP upload dir on prod/uat server)
#   ISB_PHOTO_DIR=/sftp/sftp-client/upload
#   BACKEND_BASE_URL=https://api.example.com   # public origin for photo_url in DB
# deploy.sh mounts ISB_PHOTO_DIR into the Docker container read-only.

# Legacy CDN prepend (http/https only — do NOT put a filesystem path here)
# ISB_PHOTO_BASE_URL=https://cdn.example.com/photos

# Kiosk service accounts — bun run db:seed-kiosk (must match each kiosk/.env)
KIOSK_SERVICE_USERNAME=kiosk_service
KIOSK_SERVICE_PASSWORD=kiosk1234
KIOSK_SERVICE_EMAIL=kiosk@isb-coop.local
KIOSK_SERVICE_FULL_NAME=Kiosk 1

KIOSK_SERVICE_2_USERNAME=kiosk_service_2
KIOSK_SERVICE_2_PASSWORD=kiosk1234
KIOSK_SERVICE_2_EMAIL=kiosk2@isb-coop.local
KIOSK_SERVICE_2_FULL_NAME=Kiosk 2

# Google SSO (auth-code redirect flow). Leave both blank to disable —
# /auth/sso/google/callback returns 500 in that case. Must match the OAuth
# 2.0 Client ID/Secret from Google Cloud Console (same client as the
# frontend's VITE_GOOGLE_CLIENT_ID), and that client's "Authorized redirect
# URIs" must include every frontend origin's /login path
# (e.g. https://app.example.com/login).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Outbound email (Nodemailer SMTP) — leave SMTP_HOST blank to disable.
# Required for: test email API, low-balance parent alerts, kiosk offline/online alerts.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=notifications@isb.ac.th
# SMTP_PASSWORD=your-app-password-or-smtp-secret
# SMTP_FROM_EMAIL=notifications@isb.ac.th
# SMTP_FROM_NAME=ISB Co-op
