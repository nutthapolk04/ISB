# ISB Backend URL (no trailing slash)
VITE_API_URL=https://your-backend.railway.app/api/v1

# Kiosk service account — one pair per physical device (bun run db:seed-kiosk)
# Device 1:
VITE_KIOSK_USERNAME=kiosk_service
VITE_KIOSK_PASSWORD=kiosk1234
# Device 2 example:
# VITE_KIOSK_USERNAME=kiosk_service_2
# VITE_KIOSK_PASSWORD=kiosk1234
