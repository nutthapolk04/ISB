{
  "name": "isb-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Schooney Payment System - frontend + backend (Elysia) + shared types",
  "workspaces": [
    "frontend",
    "backend-bun",
    "shared"
  ],
  "scripts": {
    "dev:backend": "bun --cwd backend-bun dev",
    "dev:frontend": "bun --cwd frontend dev",
    "dev:rfid-bridge": "npm --prefix rfid-bridge start",
    "dev:frontend:rfid": "concurrently \"bun --cwd frontend dev\" \"npm --prefix rfid-bridge start\"",
    "dev:backend:rfid": "concurrently \"bun --cwd backend-bun dev\" \"npm --prefix rfid-bridge start\"",
    "dev:all": "concurrently \"bun --cwd backend-bun dev\" \"bun --cwd frontend dev\" \"npm --prefix rfid-bridge start\"",
    "start": "npm --prefix rfid-bridge start",
    "start:rfid-bridge": "npm --prefix rfid-bridge start",
    "test:backend": "bun --cwd backend-bun test"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
