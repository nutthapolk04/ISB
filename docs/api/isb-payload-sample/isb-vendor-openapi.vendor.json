          },
          "customerType": {
            "type": "string",
            "const": "Student",
            "title": "Customertype"
          },
          "firstName": {
            "type": "string",
            "title": "Firstname",
            "examples": [
              "Kao"
            ]
          },
          "lastName": {
            "type": "string",
            "title": "Lastname",
            "examples": [
              "SUWAN"
            ]
          },
          "grade": {
            "type": "string",
            "title": "Grade",
            "description": "Zero-padded 2-digit grade, e.g. '09'.",
            "examples": [
              "09"
            ]
          },
          "schoolType": {
            "type": "string",
            "title": "Schooltype",
            "description": "One of 'ES Student' / 'MS Student' / 'HS Student'.",
            "examples": [
              "HS Student"
            ]
          },
          "profileImage": {
            "type": "string",
            "title": "Profileimage",
            "examples": [
              "35008_ST.jpg"
            ]
          },
          "smartCard": {
            "$ref": "#/components/schemas/SmartCard"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "customerId",
          "customerType",
          "firstName",
          "lastName",
          "grade",
          "schoolType",
          "profileImage",
          "smartCard"
        ],
        "title": "Student"
      },
      "SyncSuccess": {
        "properties": {
          "status": {
            "type": "string",
            "const": "SUCCESS",
            "title": "Status",
            "default": "SUCCESS"
          },
          "code": {
            "type": "string",
            "title": "Code",
            "default": "200"
