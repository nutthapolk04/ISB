  "components": {
    "schemas": {
      "Department": {
        "properties": {
          "departmentId": {
            "type": "string",
            "title": "Departmentid",
            "description": "String department id.",
            "examples": [
              "520"
            ]
          },
          "customerType": {
            "type": "string",
            "const": "Department",
            "title": "Customertype"
          },
          "departmentDescription": {
            "type": "string",
            "title": "Departmentdescription",
            "description": "Department name.",
            "examples": [
              "ED-TECH"
            ]
          },
          "login": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/StaffLogin"
              },
              {
                "type": "null"
              }
            ],
            "description": "Optional / future. An OBJECT {loginId, email} like Staff (NOT a string). A department has NO smartCard, so that key is rejected."
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "departmentId",
          "customerType",
          "departmentDescription"
        ],
        "title": "Department"
      },
      "DepartmentBatch": {
        "properties": {
          "departments": {
            "items": {
              "$ref": "#/components/schemas/Department"
            },
            "type": "array",
            "title": "Departments",
            "description": "1..batch_size departments."
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "departments"
        ],
        "title": "DepartmentBatch",
        "description": "One Department batch = one POST body. `batch_size` counts departments."
      },
      "ErrorResponse": {
        "properties": {
          "status": {
            "type": "string",
            "const": "FAILED",
            "title": "Status",
            "default": "FAILED"
          },
          "code": {
            "type": "string",
            "title": "Code",
            "examples": [
              "422"
            ]
          },
          "message": {
            "type": "string",
            "title": "Message",
            "examples": [
              "Request body does not match the ISB->Vendor contract."
            ]
          },
          "errors": {
            "anyOf": [
              {
                "items": {
                  "type": "object"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Errors",
            "description": "Validation details, when applicable."
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "title": "ErrorResponse"
      },
      "Family": {
        "properties": {
          "familyCode": {
            "type": "integer",
            "title": "Familycode",
            "description": "Equals the main parent's customerId.",
            "examples": [
              70652
            ]
          },
          "notificationEmails": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Notificationemails",
            "description": "Contact e-mails (NOT the login). May be malformed in source data; not rejected.",
            "examples": [
              [
                "kritsada.suwan@gmail.com",
                "porntips@isb.ac.th"
              ]
            ]
          },
          "mainParent": {
            "$ref": "#/components/schemas/Parent"
          },
          "secondaryParent": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/Parent"
              },
              {
                "type": "null"
              }
            ],
            "description": "`null` for single-parent families. Key is always present."
          },
          "students": {
            "items": {
              "$ref": "#/components/schemas/Student"
            },
            "type": "array",
            "title": "Students",
            "description": "1..N students in the family."
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "familyCode",
          "notificationEmails",
          "mainParent",
          "secondaryParent",
          "students"
        ],
        "title": "Family"
      },
      "FamilyBatch": {
        "properties": {
          "families": {
            "items": {
              "$ref": "#/components/schemas/Family"
            },
            "type": "array",
            "title": "Families"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "families"
        ],
        "title": "FamilyBatch",
        "description": "One Family batch = one POST body. `batch_size` counts FAMILIES, not rows."
      },
      "Parent": {
        "properties": {
          "customerId": {
            "type": "integer",
            "title": "Customerid",
            "examples": [
              70652
            ]
          },
          "customerType": {
            "type": "string",
            "enum": [
              "Parent",
              "Staff"
            ],
            "title": "Customertype",
            "description": "'Parent', or 'Staff' when the parent is also an ISB staff member."
          },
          "firstName": {
            "type": "string",
            "title": "Firstname",
            "examples": [
              "Kritsada"
            ]
          },
          "lastName": {
            "type": "string",
            "title": "Lastname",
            "examples": [
              "SUWAN"
            ]
          },
          "profileImage": {
            "type": "string",
            "title": "Profileimage",
            "examples": [
              "70652_OT.jpg"
            ]
          },
          "login": {
            "type": "string",
            "title": "Login",
            "description": "Family parent login is a STRING (contrast: staff login is an object).",
            "examples": [
              "70652@parents.isb.ac.th"
            ]
          },
          "smartCard": {
            "$ref": "#/components/schemas/SmartCard"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "customerId",
          "customerType",
          "firstName",
          "lastName",
          "profileImage",
          "login",
          "smartCard"
        ],
        "title": "Parent"
      },
      "SmartCard": {
        "properties": {
          "cardNumber": {
            "type": "string",
            "title": "Cardnumber",
            "description": "Smart-card UID. Empty string when the person has no card — ISB sends `\"\"`, it does NOT omit the object.",
            "examples": [
              "D7F8F836",
              ""
            ]
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "cardNumber"
        ],
        "title": "SmartCard"
      },
      "Staff": {
        "properties": {
          "customerId": {
            "type": "integer",
            "title": "Customerid",
            "description": "Integer customer id (never 202468.0).",
            "examples": [
              202468
            ]
          },
          "customerType": {
            "type": "string",
            "const": "Staff",
            "title": "Customertype"
          },
          "staffType": {
            "type": "string",
            "title": "Stafftype",
            "description": "e.g. 'Classified Staff', 'Certified Staff'.",
            "examples": [
              "Classified Staff"
            ]
          },
          "department": {
            "type": "string",
            "title": "Department",
            "examples": [
              "ED-TECH CENTER"
            ]
          },
          "familyCode": {
            "type": "integer",
            "title": "Familycode",
            "examples": [
              202468
            ]
          },
          "firstName": {
            "type": "string",
            "title": "Firstname",
            "examples": [
              "Jirawat"
            ]
          },
          "lastName": {
            "type": "string",
            "title": "Lastname",
            "examples": [
              "JIRACHAISOPIT"
            ]
          },
          "hasChildren": {
            "type": "boolean",
            "title": "Haschildren",
            "examples": [
              false
            ]
          },
          "profileImage": {
            "type": "string",
            "title": "Profileimage",
            "examples": [
              "202468_SF.jpg"
            ]
          },
          "smartCard": {
            "$ref": "#/components/schemas/SmartCard"
          },
          "login": {
            "$ref": "#/components/schemas/StaffLogin"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "customerId",
          "customerType",
          "staffType",
          "department",
          "familyCode",
          "firstName",
          "lastName",
          "hasChildren",
          "profileImage",
          "smartCard",
          "login"
        ],
        "title": "Staff"
      },
      "StaffBatch": {
        "properties": {
          "staffs": {
            "items": {
              "$ref": "#/components/schemas/Staff"
            },
            "type": "array",
            "title": "Staffs",
            "description": "1..batch_size staff members."
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "staffs"
        ],
        "title": "StaffBatch",
        "description": "One Staff batch = one POST body. `batch_size` counts staff members."
      },
      "StaffLogin": {
        "properties": {
          "loginId": {
            "type": "string",
            "title": "Loginid",
            "examples": [
              "jirawatj@isb.ac.th"
            ]
          },
          "email": {
            "type": "string",
            "title": "Email",
            "examples": [
              "jirawatj@isb.ac.th"
            ]
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "loginId",
          "email"
        ],
        "title": "StaffLogin",
        "description": "Staff login is an OBJECT (family parent login is a string — on purpose)."
      },
      "Student": {
